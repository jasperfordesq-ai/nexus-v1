# =============================================================================
# Project NEXUS — Public Repository .gitignore
# =============================================================================
# Only essential platform files are tracked. Everything else is excluded.
# =============================================================================

# ─── Dependencies ─────────────────────────────────────────────────────────────
/node_modules
/vendor
composer.phar

# ─── Environment & Credentials (NEVER commit) ────────────────────────────────
.env
.env.*
!.env.docker.example
!.env.example
.cloudflare-api-token
.build-version

# ─── Documentation (private — not for public repo) ───────────────────────────
/docs/*
!/docs/legal/
!/docs/database-migrations.md
!/docs/DEPLOYMENT.md
!/docs/SYSTEM_AUDIT_*.md
!/docs/API_REFERENCE.md
!/docs/FEDERATION.md
!/docs/OPEN_SOURCE_ANNOUNCEMENT_EMAIL.md
!/docs/OPEN_SOURCE_ANNOUNCEMENT_EMAIL.html
!/docs/OPEN_SOURCE_ANNOUNCEMENT_EMAIL.pdf
!/docs/SERVICE_LAYER.md
!/docs/MIGRATIONS.md
!/docs/DOCKER.md
!/docs/database/
!/docs/database/*.md

# ─── AI Assistant Config (contains sensitive project context) ─────────────────
CLAUDE.md
.agent/
.claude/

# ─── All Markdown in root except licensing files ──────────────────────────────
/*.md
!README.md
!CONTRIBUTORS.md
!CONTRIBUTING.md
!CHANGELOG.md

# ─── Scripts & Migrations (internal, contain credentials/emails) ──────────────
/scripts/*
!/scripts/verify-admin-security.sh
!/scripts/check-regression-patterns.sh
!/scripts/check-dockerfile-drift.sh
!/scripts/verify-feature.sh
!/scripts/add-spdx-headers.mjs
!/scripts/check-spdx.mjs
!/scripts/safe_migrate.php
!/scripts/backfill_embeddings.php
!/scripts/sync_search_index.php
!/scripts/train_recommendations.php
!/scripts/batch_geocode_users.php
!/scripts/post-deploy-algorithms.sh
!/scripts/migrate-production.sh
!/scripts/backup-production-db.sh
!/scripts/server-nightly-backup.sh
!/scripts/setup-rclone-gdrive.sh
!/scripts/setup-rclone-local.sh
!/scripts/check-migration-drift.sh
!/scripts/check-migration-ci.sh
!/scripts/maintenance.sh
!/scripts/safe-deploy.sh
!/scripts/safe-deploy.sh.bak
!/scripts/deploy/
!/scripts/deploy/**
!/scripts/purge-cloudflare-cache.sh
!/scripts/refresh-schema-dump.sh
!/scripts/check-i18n.sh
!/scripts/generate-announcement-pdf.mjs
!/scripts/check-i18n-drift.mjs
!/scripts/check-i18n-stubs.mjs
!/scripts/check-i18n-coverage.mjs
!/scripts/check-i18n-vars.mjs
!/scripts/check-php-i18n-coverage.mjs
!/scripts/check-admin-breadcrumbs.mjs
!/scripts/translate-i18n-gaps.mjs
!/scripts/prerender-tenants.sh
!/scripts/prerender-worker.mjs
!/scripts/audit-static-services.php
!/scripts/audit-fk-cascade.php
!/scripts/check-container-health.sh
!/scripts/check-no-new-legacy-sql.sh
!/scripts/check-schema-drift.sh
!/scripts/test-artisan-cache.sh
!/scripts/pre-push-checks.sh
!/scripts/validate-env.php

# ─── Deploy & Production Config ───────────────────────────────────────────────
compose.prod.yml
.deployignore

# ─── Docker Config (local dev, contains credentials) ──────────────────────────
/docker/
!/docker/entrypoint-cache.sh

# ─── Downloads & Binary Assets ─────────────────────────────────────────────────
/httpdocs/downloads/
*.apk

# ─── E2E Testing (Playwright) ────────────────────────────────────────────────
playwright-report/
test-results/

# ─── Mobile App (on hold — not in active development) ───────────────────────
/mobile/
/capacitor/

# ─── Old/Quarantined Directories ─────────────────────────────────────────────
react-frontend__quarantine_*/
_deprecated/
--version/

# ─── Old Git Hooks (replaced by .husky) ──────────────────────────────────────
/.githooks/

# ─── Backups, Exports, Storage, Uploads ───────────────────────────────────────
/backups/
/exports/
/storage/
/uploads/
/httpdocs/uploads/
/httpdocs/storage
/httpdocs/storage/

# ─── Build Outputs & Caches ──────────────────────────────────────────────────
/public/build
/public/hot
/public/storage
/public/css
/public/js
/public/mix-manifest.json
/cache
/.phpunit.cache
.snapshots

/coverage/
**/coverage/
/bootstrap/cache/
# ─── Logs ─────────────────────────────────────────────────────────────────────
/logs
*.log

# ─── Database Files ───────────────────────────────────────────────────────────
*.sqlite
*.sqlite-journal
database.sqlite
schema_production.sql
dump.sql

# ─── SQL Scripts in Root ──────────────────────────────────────────────────────
/*.sql
!schema.sql

# ─── Archives & Binaries ─────────────────────────────────────────────────────
*.zip
*.tar
*.tar.gz
*.sql.gz
*.rar
*.pdf
!/docs/OPEN_SOURCE_ANNOUNCEMENT_EMAIL.pdf

# ─── Temporary Files ─────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.backup
nul
debug_output.html
tmp_*.php
tmp_*.json
tmp_*.sh
tmp_*.txt
*.timestamp-*.mjs
C?temp*
C?tmp*
C?Users*
c?xampp*
*tempcivicone_dirs.txt
*tempmodern_dirs.txt

# ─── Stray Test/Debug Files in Root ───────────────────────────────────────────
test-*.php
test_*.php
diagnose-*.php
debug-*.php
verify-*.php
admin_routes.txt
drawer_good.txt
navbar_good.txt
privacy-page.min.css
production-status.log
*.min.css

# ─── IDE & OS Files ──────────────────────────────────────────────────────────
.idea
.vscode
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Credentials & Secrets ───────────────────────────────────────────────────
firebase-service-account.json
*.pem
*.key
*-api-token*
cloudflare-api-token.txt

# ─── Scratch Scripts & Debug Artifacts ───────────────────────────────────────
_*.py
_*.js
_*.txt
_*.php
/tests/debug/
/routes/_pysetup.py
react-frontend/_nul
react-frontend/fix_tests.py
httpdocs/assets/css/admin-legacy-compat.css
*.jpg
!httpdocs/uploads/**/*.jpg

# ─── Stray CLI Artifacts ────────────────────────────────────────────────────
--help
0
tests/Services/test_*.txt
Ctemp*

# ─── Data exports (PII) ───────────────────────────────────────────────────────
*.csv

# ─── Legacy analysis / scratch artifacts (cleanup 2026-04-13) ────────────────
# Prevent recurrence of the stray root-level junk (summary dumps, ad-hoc scripts,
# and one-off legacy archaeology). If any of these patterns is legitimately
# needed in tree, add a negated exception.
legacy_*
legacy_files/
*_temp.php
*_temp.sh
analyze_*.sh
create_*_summary.sh

# ─── Confidential legal documents (never commit) ─────────────────────────────
DPO_Confidentiality_Agreement_*.docx
*.docx
.codex_tmp/
