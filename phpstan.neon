# PHPStan configuration.
#
# NOTE on baselines: PHPStan 1.12's --generate-baseline emits invalid NEON
# (escaped colons like "\:" that the NEON parser rejects). Do NOT run
# --generate-baseline until the upstream bug is fixed. Instead, the
# pre-existing ~123 errors are suppressed via explicit `ignoreErrors`
# patterns below. CI/pre-push run phpstan as warning-only (|| true).
# See memory: feedback / PHPStan section in MEMORY.md.
parameters:
    level: 3
    paths:
        - src
    excludePaths:
        - src/Views
        - vendor
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        - '#Call to an undefined method#'
        - '#Access to an undefined property#'
        - identifier: missingType.iterableValue
        - message: '#should always throw an exception or terminate script execution#'
          path: src/Controllers/Api/BaseApiController.php

        # SocialApiController: Non-standard PHPDoc @param tags (missing $ prefix).
        # These are doc-only descriptions for request body params, not PHP method params.
        - message: '#PHPDoc tag @param has invalid value#'
          path: src/Controllers/Api/SocialApiController.php

        # ActivityLog: Optional service class that may not be present in all deployments.
        # DeliverabilityTrackingService and Review model call it wrapped in class_exists checks.
        - message: '#Call to static method log\(\) on an unknown class Nexus\\Services\\ActivityLog#'

        # GmailApiHelper: Optional Gmail API helper loaded dynamically.
        - message: '#Call to static method testConnection\(\) on an unknown class Nexus\\Services\\GmailApiHelper#'

        # TextHelper: Optional helper class used via class-exists-guarded call in AdminGroupsApiController.
        - message: '#Call to static method slugify\(\) on an unknown class Nexus\\Helpers\\TextHelper#'

        # Event::getUpcoming: Method called inside class_exists guard in EmailTemplateBuilder.
        - message: '#Call to an undefined static method Nexus\\Models\\Event::getUpcoming\(\)#'

        # NotificationService::create: Called inside class_exists guard in JobVacancyService.
        - message: '#Call to an undefined static method Nexus\\Services\\NotificationService::create\(\)#'

        # RedisCache: PHP Redis extension type quirks — del() and exists() return mixed types
        # depending on Redis extension version. The comparison is correct at runtime.
        - message: '#Comparison operation ">" between \(int\|Redis\|false\) and 0#'
          path: src/Services/RedisCache.php
        - message: '#Comparison operation ">" between \(bool\|int\|Redis\) and 0#'
          path: src/Services/RedisCache.php

        # empty() on always-defined variables: PHPStan is overly strict here.
        # empty() on a string or array variable that could be empty-string/null/[] is valid defensive PHP.
        - message: '#Variable \$email in empty\(\) always exists and is not falsy#'
          path: src/Controllers/Api/AuthController.php
        - message: '#Variable \$uploadedFile in empty\(\) always exists and is not falsy#'
          path: src/Controllers/Api/VolunteerApiController.php
        - message: '#Variable \$categoryFilter in empty\(\) always exists and is not falsy#'
          path: src/Services/SmartMatchingEngine.php
        - message: '#Variable \$password in empty\(\) always exists and is not falsy#'
          path: src/Services/TwoFactorChallengeManager.php
        - message: '#Variable \$password in empty\(\) always exists and is not falsy#'
          path: src/Services/RedisCache.php

        # GamificationService: Constructor accepts $db for backward compatibility with
        # NexusScoreService and NexusScoreController which pass a PDO instance.
        # All GamificationService methods are static so $db is intentionally unused.
        - message: '#Constructor of class Nexus\\Services\\GamificationService has an unused parameter \$db#'
          path: src/Services/GamificationService.php
