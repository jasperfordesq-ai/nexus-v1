# Block directory listing
Options -Indexes

# Redirect bare directory access to home page (instead of 403 error)
# Only redirect if the request is for a directory AND not a real file
DirectoryIndex disabled
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^.*$ / [R=301,L]

# Allow direct file access for images, videos, audio (voice messages) and
# documents (Apache 2.4 syntax). Audio extensions (m4a/webm/ogg/wav/aac/mp3)
# back the in-app voice-message player — without them a fresh image-based
# deploy would 403 voice files. (Production's uploads volume has no FilesMatch
# restriction, so it already serves audio; this keeps the repo copy correct.)
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|pdf|doc|docx|txt|csv|xls|xlsx|mp4|mov|avi|apk|m4a|webm|ogg|wav|aac|mp3)$">
    Require all granted
</FilesMatch>

# Force download for certain file types (documents/spreadsheets — never render
# inline; message attachments allow these via MessageAttachmentUploader).
<FilesMatch "\.(pdf|doc|docx|txt|csv|xls|xlsx|apk)$">
    Header set Content-Disposition "attachment"
</FilesMatch>
