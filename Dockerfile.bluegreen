# =============================================================================
# Project NEXUS - Immutable PHP Runtime for Blue/Green Deploys
# =============================================================================

FROM php:8.2.30-apache

ARG DEBIAN_FRONTEND=noninteractive

# `apt-get -y upgrade` first: the pinned php base image ships Debian packages
# that accumulate known CVEs between its releases — the Trivy container gate
# blocks on fixed-but-not-installed CRITICAL/HIGH findings.
RUN apt-get -o Acquire::Retries=3 update && apt-get -o Acquire::Retries=3 -y upgrade && apt-get -o Acquire::Retries=3 install -y --no-install-recommends \
    libpng-dev \
    libjpeg-dev \
    libwebp-dev \
    libfreetype6-dev \
    libicu-dev \
    libzip-dev \
    libonig-dev \
    libxml2-dev \
    libcurl4-openssl-dev \
    libgmp-dev \
    curl \
    unzip \
    git \
    webp \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

RUN docker-php-ext-configure gd \
        --with-freetype \
        --with-jpeg \
        --with-webp \
    && docker-php-ext-install -j"$(nproc)" \
        pdo_mysql \
        gd \
        exif \
        intl \
        zip \
        mbstring \
        bcmath \
        gmp \
        opcache \
        xml \
        curl \
        fileinfo \
        pcntl

# pecl.php.net intermittently 504s / serves truncated tarballs, which repeatedly
# broke CI ("Docker Build Verify") and production image builds on an unchanged
# line. Retry with backoff and a clean download dir each attempt so a transient
# blip doesn't fail the build; fail hard only after 5 genuine failures.
RUN ok=0; \
    for i in 1 2 3 4 5; do \
        rm -rf /tmp/pear/download/* 2>/dev/null || true; \
        if pecl install redis; then ok=1; break; fi; \
        echo "pecl install redis failed (attempt $i/5)" >&2; \
        if [ "$i" -lt 5 ]; then sleep "$((i * 10))"; fi; \
    done; \
    if [ "$ok" != 1 ]; then echo "pecl install redis failed after 5 attempts" >&2; exit 1; fi; \
    docker-php-ext-enable redis

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

RUN a2enmod rewrite headers expires deflate ssl remoteip

ENV APACHE_DOCUMENT_ROOT=/var/www/html/httpdocs

RUN sed -ri -e 's!/var/www/html!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/sites-available/*.conf \
    && sed -ri -e 's!/var/www/!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/apache2.conf /etc/apache2/conf-available/*.conf \
    && sed -i '/<Directory \/var\/www\/>/,/<\/Directory>/ s/AllowOverride None/AllowOverride All/' /etc/apache2/apache2.conf

RUN printf '<IfModule remoteip_module>\n\
  RemoteIPHeader CF-Connecting-IP\n\
  RemoteIPTrustedProxy 173.245.48.0/20\n\
  RemoteIPTrustedProxy 103.21.244.0/22\n\
  RemoteIPTrustedProxy 103.22.200.0/22\n\
  RemoteIPTrustedProxy 103.31.4.0/22\n\
  RemoteIPTrustedProxy 141.101.64.0/18\n\
  RemoteIPTrustedProxy 108.162.192.0/18\n\
  RemoteIPTrustedProxy 190.93.240.0/20\n\
  RemoteIPTrustedProxy 188.114.96.0/20\n\
  RemoteIPTrustedProxy 197.234.240.0/22\n\
  RemoteIPTrustedProxy 198.41.128.0/17\n\
  RemoteIPTrustedProxy 162.158.0.0/15\n\
  RemoteIPTrustedProxy 104.16.0.0/13\n\
  RemoteIPTrustedProxy 104.24.0.0/14\n\
  RemoteIPTrustedProxy 172.64.0.0/13\n\
  RemoteIPTrustedProxy 131.0.72.0/22\n\
  RemoteIPTrustedProxy 2400:cb00::/32\n\
  RemoteIPTrustedProxy 2606:4700::/32\n\
  RemoteIPTrustedProxy 2803:f800::/32\n\
  RemoteIPTrustedProxy 2405:b500::/32\n\
  RemoteIPTrustedProxy 2405:8100::/32\n\
  RemoteIPTrustedProxy 2a06:98c0::/29\n\
  RemoteIPTrustedProxy 2c0f:f248::/32\n\
  RemoteIPTrustedProxy 172.16.0.0/12\n\
  RemoteIPTrustedProxy 10.0.0.0/8\n\
  RemoteIPTrustedProxy 192.168.0.0/16\n\
  RemoteIPTrustedProxy 127.0.0.0/8\n\
</IfModule>\n' > /etc/apache2/conf-available/remoteip.conf \
    && a2enconf remoteip

RUN echo 'PassEnv DB_HOST DB_PORT DB_NAME DB_USER DB_PASS DB_TYPE REDIS_HOST REDIS_PORT APP_ENV APP_DEBUG APP_URL APP_KEY JWT_SECRET PUSHER_APP_KEY PUSHER_APP_SECRET PUSHER_APP_ID PUSHER_APP_CLUSTER OPENAI_API_KEY SENTRY_DSN_PHP SENTRY_ENVIRONMENT SENTRY_TRACES_SAMPLE_RATE ADMIN_NOTIFICATION_EMAIL MEILISEARCH_HOST MEILISEARCH_KEY SENDGRID_API_KEY SENDGRID_FROM_EMAIL SENDGRID_FROM_NAME EMAIL_ENCRYPTION_KEY USE_GMAIL_API GMAIL_CLIENT_ID GMAIL_CLIENT_SECRET GMAIL_REFRESH_TOKEN GMAIL_SENDER_EMAIL GMAIL_SENDER_NAME SMTP_HOST SMTP_PORT SMTP_USER SMTP_PASS SMTP_ENCRYPTION SMTP_FROM_EMAIL SMTP_FROM_NAME STRIPE_SECRET_KEY STRIPE_PUBLISHABLE_KEY STRIPE_WEBHOOK_SECRET STRIPE_IDENTITY_SECRET_KEY STRIPE_IDENTITY_WEBHOOK_SECRET VERIFF_API_KEY VERIFF_API_SECRET JUMIO_API_TOKEN JUMIO_API_SECRET ONFIDO_API_TOKEN ONFIDO_WEBHOOK_SECRET IDENFY_API_KEY IDENFY_API_SECRET REACT_FRONTEND_URL' >> /etc/apache2/conf-available/passenv.conf \
    && a2enconf passenv

RUN printf '<Directory /var/www/html/storage/app/public>\n\
    Options FollowSymLinks\n\
    AllowOverride None\n\
    Require all granted\n\
</Directory>\n\
Alias /storage /var/www/html/storage/app/public\n' \
    > /etc/apache2/conf-available/storage-alias.conf \
    && a2enconf storage-alias

RUN echo 'ServerTokens Prod' >> /etc/apache2/conf-available/security.conf \
    && echo 'ServerSignature Off' >> /etc/apache2/conf-available/security.conf \
    && a2enconf security

RUN a2enmod headers \
    && printf 'Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"\n\
Header always set X-Frame-Options "SAMEORIGIN"\n\
Header always set X-Content-Type-Options "nosniff"\n\
Header always set Referrer-Policy "strict-origin-when-cross-origin"\n\
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self), payment=(self)"\n\
Header always set Content-Security-Policy "default-src '"'"'self'"'"'; script-src '"'"'self'"'"' https://js.stripe.com https://maps.googleapis.com https://challenges.cloudflare.com; style-src '"'"'self'"'"' '"'"'unsafe-inline'"'"' https://fonts.googleapis.com; font-src '"'"'self'"'"' https://fonts.gstatic.com; img-src '"'"'self'"'"' data: https:; connect-src '"'"'self'"'"' wss: https://api.stripe.com https://maps.googleapis.com https://challenges.cloudflare.com https://api.pwnedpasswords.com; frame-src https://js.stripe.com https://hooks.stripe.com https://challenges.cloudflare.com; object-src '"'"'none'"'"'; base-uri '"'"'self'"'"'; form-action '"'"'self'"'"'; report-uri /api/v2/csp-report"\n' \
    > /etc/apache2/conf-available/security-headers.conf \
    && a2enconf security-headers

RUN mv "$PHP_INI_DIR/php.ini-production" "$PHP_INI_DIR/php.ini"

RUN echo "\n\
display_errors = Off\n\
display_startup_errors = Off\n\
error_reporting = E_ALL & ~E_DEPRECATED & ~E_STRICT\n\
log_errors = On\n\
error_log = /var/log/php_errors.log\n\
memory_limit = 1G\n\
max_execution_time = 120\n\
max_input_time = 120\n\
max_input_vars = 3000\n\
upload_max_filesize = 100M\n\
post_max_size = 105M\n\
max_file_uploads = 20\n\
session.gc_maxlifetime = 7200\n\
session.cookie_httponly = 1\n\
session.cookie_secure = 1\n\
session.cookie_samesite = Lax\n\
session.use_strict_mode = 1\n\
date.timezone = UTC\n\
opcache.enable = 1\n\
opcache.memory_consumption = 256\n\
opcache.interned_strings_buffer = 32\n\
opcache.max_accelerated_files = 20000\n\
opcache.validate_timestamps = 0\n\
opcache.revalidate_freq = 0\n\
opcache.revalidate_path = 1\n\
opcache.save_comments = 1\n\
opcache.enable_cli = 0\n\
opcache.preload=/var/www/html/docker/preload.php\n\
opcache.preload_user=www-data\n\
expose_php = Off\n\
allow_url_fopen = On\n\
allow_url_include = Off\n\
" >> "$PHP_INI_DIR/php.ini"

WORKDIR /var/www/html

COPY docker/preload.php /var/www/html/docker/preload.php

COPY composer.json composer.lock ./
# Retry composer install — packagist / GitHub archive downloads flake intermittently
# and a single transient blip should not fail a production image build.
RUN ok=0; \
    for i in 1 2 3; do \
        if composer install --no-dev --prefer-dist --no-interaction --no-progress --optimize-autoloader --no-scripts; then ok=1; break; fi; \
        echo "composer install failed (attempt $i/3)" >&2; \
        if [ "$i" -lt 3 ]; then sleep "$((i * 10))"; fi; \
    done; \
    if [ "$ok" != 1 ]; then echo "composer install failed after 3 attempts" >&2; exit 1; fi

COPY accessible-frontend ./accessible-frontend
COPY app ./app
COPY assets ./assets
COPY bootstrap ./bootstrap
COPY config ./config
COPY database ./database
COPY httpdocs ./httpdocs
COPY lang ./lang
COPY resources ./resources
COPY routes ./routes
COPY views ./views
COPY artisan ./artisan
# Include the operational scripts directory so commands that run inside the
# container (the raw-SQL migration gate, audit scripts, etc) have access to
# them at deploy time. The directory is heavily git-allowlisted; only files
# explicitly un-ignored in .gitignore are present in the build context.
COPY scripts ./scripts
COPY migrations ./migrations

# Bake the build commit into the image so /version.php has a valid commit field
# the moment a container starts — closes the race window where the drift
# watchdog could see an empty/unknown commit between container start and the
# orchestrator's docker cp of .build-version. The orchestrator still overwrites
# this file later with full metadata (deployed_at, commit_message), but the
# fallback baked here means version.php is NEVER without a commit.
ARG BUILD_COMMIT=unknown
RUN printf '{"service":"nexus-php-api","commit":"%s","commit_short":"%s","deployed_at":"image-build","deploy_mode":"bluegreen"}\n' \
        "$BUILD_COMMIT" "$(echo "$BUILD_COMMIT" | cut -c1-8)" \
        > /var/www/html/httpdocs/.build-version \
    && chmod 644 /var/www/html/httpdocs/.build-version

RUN mkdir -p /var/www/html/storage/app/public \
             /var/www/html/storage/framework/cache/data \
             /var/www/html/storage/framework/sessions \
             /var/www/html/storage/framework/views \
             /var/www/html/storage/logs \
             /var/www/html/bootstrap/cache \
             /var/www/html/httpdocs/uploads/tenants \
             /var/www/html/httpdocs/uploads/posts \
    && rm -rf /var/www/html/httpdocs/storage \
    && ln -sfn /var/www/html/storage/app/public /var/www/html/httpdocs/storage \
    && composer dump-autoload --no-dev --optimize --no-interaction \
    && chown -R www-data:www-data /var/www/html \
    && chmod -R 775 /var/www/html/storage /var/www/html/bootstrap/cache

# setgid on storage/cache dirs so files created by any process (incl. the
# root-run queue/scheduler containers with umask 0002) inherit the www-data
# group and stay group-writable — prevents the cross-container "Permission
# denied" on the daily log file regardless of which container writes it first.
RUN find /var/www/html/storage /var/www/html/bootstrap/cache -type d -exec chmod 2775 {} +

# Run package:discover so that auto-discovered service providers (Horizon,
# Sanctum, etc.) are written into bootstrap/cache/packages.php inside the
# image. Without this, --no-scripts skips discovery and Horizon commands
# are absent at runtime when the bootstrap/cache volume is mounted.
RUN php artisan package:discover --ansi 2>/dev/null || true

# Pre-publish Horizon dashboard assets so they're baked into the image.
RUN php artisan horizon:publish 2>/dev/null || true

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost/health.php || exit 1

CMD ["sh", "-c", "umask 0002; \
    mkdir -p /var/www/html/storage/logs /var/www/html/storage/framework/cache/data /var/www/html/storage/framework/sessions /var/www/html/storage/framework/views /var/www/html/bootstrap/cache /var/www/html/httpdocs/uploads/tenants /var/www/html/httpdocs/uploads/posts; \
    if ! chown -R www-data:www-data /var/www/html/storage /var/www/html/bootstrap/cache; then echo '[WARN] startup chown failed — log writes may fail'; fi; \
    if ! find /var/www/html/storage /var/www/html/bootstrap/cache -type d -exec chmod 2775 {} +; then echo '[WARN] startup chmod dirs failed'; fi; \
    if ! find /var/www/html/storage /var/www/html/bootstrap/cache -type f -exec chmod 664 {} +; then echo '[WARN] startup chmod files failed'; fi; \
    if ! chown -R www-data:www-data /var/www/html/httpdocs/uploads; then echo '[WARN] startup upload chown failed - uploads may fail'; fi; \
    if ! chmod -R ug+rwX,o+rX /var/www/html/httpdocs/uploads; then echo '[WARN] startup upload chmod failed - uploads may fail'; fi; \
    php artisan optimize || { echo '[FATAL] artisan optimize failed'; exit 1; }; \
    php artisan horizon:publish 2>/dev/null || true; \
    chown -R www-data:www-data /var/www/html/storage /var/www/html/bootstrap/cache 2>/dev/null || true; \
    exec apache2-foreground"]
