# Project NEXUS - Environment Configuration Example
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ==============================================
# APPLICATION SETTINGS
# ==============================================
APP_ENV=development
APP_DEBUG=true
APP_KEY=base64:generate-a-random-32-byte-key-here
APP_URL=http://localhost:5173

# First-run bootstrap admin created by `php artisan db:seed`.
# Development defaults are admin@project-nexus.local / ChangeMe123!.
# Production installs should set their own values before seeding.
NEXUS_BOOTSTRAP_ADMIN_EMAIL=admin@project-nexus.local
NEXUS_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nexus
DB_USERNAME=root
DB_PASSWORD=
DB_ROOT_PASSWORD=change_me

# ==============================================
# CORS & SECURITY
# ==============================================
# WebAuthn / Passkeys RP ID (must match the domain)
# Production: project-nexus.ie  |  Local dev: localhost
WEBAUTHN_RP_ID=project-nexus.ie

# TOTP two-factor encryption key (must be exactly 32 characters)
# Generate with: openssl rand -hex 16
TOTP_ENCRYPTION_KEY=your-32-char-encryption-key-here
# Comma-separated list of allowed origins for CORS (examples — adapt to your deployment)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8082,http://127.0.0.1:8082,http://localhost:8090,https://app.project-nexus.ie,https://api.project-nexus.ie

# Comma-separated list of allowed hosts for redirects (examples — adapt to your deployment)
ALLOWED_HOSTS=localhost:5173,localhost:8082,127.0.0.1:8082,localhost:8090,app.project-nexus.ie,api.project-nexus.ie

# ==============================================
# PUSHER / REAL-TIME
# ==============================================
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu
PUSHER_DEBUG=false

# ==============================================
# EMAIL CONFIGURATION
# ==============================================

# SMTP (Default — reliable, recommended for most setups)
# Uses Gmail App Password or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=noreply@project-nexus.ie
SMTP_FROM_NAME="Project NEXUS"

# Gmail API (Optional — OAuth2, auto-refreshing tokens)
# Set USE_GMAIL_API=true to enable, false to use SMTP above
# Setup: php scripts/gmail-oauth-setup.php
# Test:  php scripts/test-gmail-api.php
# Docs:  https://console.cloud.google.com/apis/library/gmail.googleapis.com
#
# Token caching: Redis (persistent across requests, ~1 refresh per hour)
# Rate limit: max 10 token refreshes per hour
# Circuit breaker: 3 consecutive failures → 5 min Gmail API pause → SMTP fallback
# SMTP fallback: always available when Gmail API fails
USE_GMAIL_API=false
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
GMAIL_SENDER_NAME="Project NEXUS"

# Email body encryption key (used by outbound email log encryption)
# Generate with: openssl rand -base64 32
EMAIL_ENCRYPTION_KEY=

# SendGrid (optional — used when email provider is set to 'sendgrid')
SENDGRID_API_KEY=SG....
# ECDSA public key for verifying signed event webhooks (raw base64, single line — no PEM headers)
# Get from: SendGrid Dashboard → Mail Settings → Event Webhook → Edit → Enable Signed Event Webhook
SENDGRID_WEBHOOK_VERIFICATION_KEY=MFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAE...

# Platform email provider for the custom App\Core\Mailer path.
# 'sendgrid' (default) keeps existing behaviour; 'postmark' routes platform
# mail through Postmark (SendGrid stays wired as an automatic fallback).
MAIL_PLATFORM_PROVIDER=sendgrid

# Postmark (used when MAIL_PLATFORM_PROVIDER=postmark)
# Server API token — Postmark → Servers → <server> → API Tokens
POSTMARK_SERVER_TOKEN=
# Shared secret for the event webhook (Basic Auth password / X-Postmark-Webhook-Secret)
POSTMARK_WEBHOOK_SECRET=
# Optional overrides (sensible defaults applied in config/mail.php)
POSTMARK_FROM_DOMAIN=project-nexus.net
POSTMARK_STREAM_TRANSACTIONAL=outbound
POSTMARK_STREAM_BROADCAST=broadcast

# Error Alerts
ERROR_ALERT_EMAIL=admin@project-nexus.ie
ERROR_ALERT_FROM=errors@project-nexus.ie
ADMIN_EMAIL=admin@project-nexus.ie

# ==============================================
# AI PROVIDERS
# ==============================================
# Default AI Provider (gemini, openai, anthropic, ollama)
AI_DEFAULT_PROVIDER=gemini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Ollama (Local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2

# ==============================================
# CACHE & SESSION
# ==============================================
CACHE_DRIVER=redis
SESSION_DRIVER=file
QUEUE_CONNECTION=redis
# Note: use QUEUE_CONNECTION=sync only in testing environments (config/queue.php)

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# ==============================================
# PODCAST MEDIA STORAGE (optional cloud offload)
# ==============================================
# Podcast audio is stored on the 'local' disk (storage/app/private) by default,
# which persists across blue/green deploys via the nexus-php-storage volume.
# To offload to any S3-compatible provider (AWS S3, Cloudflare R2,
# DigitalOcean Spaces, MinIO), fill these in and flip the per-tenant setting
# podcasts.media_storage_driver to 'cloud' in Admin → Config → Podcasts.
# Verify credentials first: php artisan podcasts:storage-doctor --disk=s3
# Migrate existing audio:   php artisan podcasts:migrate-media --to=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=
# Public/CDN base URL for the bucket (optional; else temporary signed URLs are used)
AWS_URL=
# Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com | MinIO: http://minio:9000
AWS_ENDPOINT=
# MinIO and some S3-compatibles need path-style: set to true
AWS_USE_PATH_STYLE_ENDPOINT=false

# Optional ClamAV daemon for scanning uploaded podcast audio (clamd INSTREAM).
# Unset = scanning reported as 'scan_unavailable' (uploads are never blocked).
# Example: tcp://127.0.0.1:3310 or tcp://clamav:3310
CLAMAV_ADDRESS=

# ==============================================
# FEDERATION
# ==============================================
FEDERATION_ENABLED=true
FEDERATION_JWT_SECRET=generate-a-random-secret-here
FEDERATION_API_VERSION=v1

# General JWT signing secret (auth tokens, API tokens)
# Generate with: openssl rand -hex 32
JWT_SECRET=generate-a-random-secret-here

# ==============================================
# CRON / BACKGROUND JOBS
# ==============================================
# Secret key for authenticating cron requests via HTTP.
# MUST be set to a 32+ character random string. Generate with:
#   openssl rand -hex 32
# Leave unset here — set explicitly in your real .env file.
CRON_KEY=

# ==============================================
# LOGGING & DEBUGGING
# ==============================================
LOG_CHANNEL=file
LOG_LEVEL=warning
# Channels in the "stack" logger (config/logging.php LOG_STACK, default daily,stderr).
# Include `sentry` so Log::error/critical from background jobs (e.g. the
# federation reconcile job) and the Stripe webhook handler reach Sentry.
# PRODUCTION should set:  LOG_STACK=daily,stderr,sentry
LOG_STACK=daily,stderr
DEBUG=false
DB_PROFILING=false

# ==============================================
# SENTRY ERROR TRACKING
# ==============================================
# Get your DSN from https://sentry.io/settings/projects/
# PHP Backend DSN
SENTRY_DSN_PHP=
# React Frontend DSN (can be the same or different project)
SENTRY_DSN_REACT=
# Environment (production, staging, development)
SENTRY_ENVIRONMENT=production
# Performance monitoring sample rate (0.0 to 1.0)
# 0.1 = 10% of transactions, 1.0 = 100% of transactions
SENTRY_TRACES_SAMPLE_RATE=0.1

# ==============================================
# OPS ALERTING (Slack incoming webhooks, optional)
# ==============================================
# Money / reliability alerts: slo:check (exchange SLO) and
# stripe:check-stuck-webhooks (Stripe webhook events stuck in 'failed').
# Left blank = those checks log + Sentry only (still safe), no Slack push.
SLACK_SLO_ALERTS_WEBHOOK=
# Email-deliverability pager: email:health-alert
SLACK_EMAIL_ALERTS_WEBHOOK=

# ==============================================
# GDPR COMPLIANCE
# ==============================================
GDPR_DPA_EMAIL=dpo@project-nexus.ie
GDPR_REQUEST_EXPIRY_DAYS=30

# ==============================================
# ENTERPRISE FEATURES
# ==============================================
VAULT_ENABLED=false
VAULT_URL=
VAULT_TOKEN=

METRICS_ENABLED=false
DD_AGENT_HOST=

# ==============================================
# TENOR GIF SEARCH (Optional)
# ==============================================
# Free API key for GIF search — get one at https://developers.google.com/tenor/guides/quickstart
VITE_TENOR_API_KEY=

# ==============================================
# FEATURE FLAGS
# ==============================================
FEATURE_AI_CHAT=true
FEATURE_GAMIFICATION=true
FEATURE_FEDERATION=true
FEATURE_WEBPUSH=true

# ==============================================
# WEB PUSH NOTIFICATIONS
# ==============================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@project-nexus.ie

# ==============================================
# MAILCHIMP (Optional)
# ==============================================
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# ==============================================
# SOCIAL AUTH (Optional)
# ==============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ==============================================
# PRODUCTION DATABASE (for migration scripts)
# ==============================================
# Used by: make migrate-prod, make backup-prod-db, make drift-check
# These are NOT used by the application — only by CLI migration scripts.
# Set these in your local .env to avoid typing credentials each time.
# deployment only
PROD_SSH_KEY=C:\ssh-keys\project-nexus.pem
PROD_SSH_HOST=azureuser@20.224.171.253
PROD_DB_NAME=nexus
# PROD_DB_USER and PROD_DB_PASS are auto-read from the server .env
# Set them here only if you want to skip the SSH credential lookup:
# PROD_DB_USER=
# PROD_DB_PASS=

# ==============================================
# STRIPE
# ==============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Identity Verification
STRIPE_IDENTITY_SECRET_KEY=sk_live_...
STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_...

# Cloudflare Turnstile (bot challenge on registration / contact forms)
# Site key is public — embedded in HTML. Secret key MUST be kept secret.
# Use test keys for local dev:
#   TURNSTILE_SITE_KEY=1x00000000000000000000AA          # always passes
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# Leaving these unset disables Turnstile entirely (widget not rendered, server skips verify).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ==============================================
# MAPS / SEARCH / CORS (read by app code)
# ==============================================
# Google Maps JS API key — only served to the browser when the tenant has
# maps=on AND map_provider=google (see MapsConfigController)
GOOGLE_MAPS_API_KEY=

# Google Maps Map ID — REQUIRED for markers to render with the Google provider.
# Google AdvancedMarkers (used for every pin) silently render nothing without a
# Map ID, which looks like "the map loads but is empty / doesn't display
# correctly". Create one at Google Cloud Console > Maps > Map Management and
# enable it for the Maps JavaScript API. Platform-wide fallback; a tenant can
# override it via the admin "Maps & location" card (general.google_maps_map_id).
# When unset and no per-tenant Map ID exists, the frontend falls back to classic
# (legacy) markers so pins still render.
GOOGLE_MAPS_MAP_ID=

# Ordnance Survey Data Hub project key — used when map_provider=ordnance_survey
# or geocoding_provider=os_places (UK tenants; PSGA-covered public bodies).
# Platform-wide fallback; per-tenant override is general.os_maps_api_key.
OS_MAPS_API_KEY=

# Meilisearch master/API key (Docker dev default container has none)
MEILISEARCH_KEY=

# Comma-separated list of additional allowed CORS origins
CORS_ALLOWED_ORIGINS=

# Stripe Connect marketplace webhook (separate endpoint from the main webhook)
STRIPE_MARKETPLACE_WEBHOOK_SECRET=

# ==============================================
# REGISTRATION ABUSE CONTROLS (optional)
# ==============================================
# Max registrations per tenant per hour (0/unset = no cap)
REGISTRATION_TENANT_HOURLY_CAP=
# Require a verified location before registration completes (true/false)
REGISTRATION_REQUIRE_VERIFIED_LOCATION=

# ==============================================
# HASHICORP VAULT (optional secret backend)
# ==============================================
USE_VAULT=false
VAULT_TOKEN=
VAULT_ROLE_ID=
VAULT_SECRET_ID=
