{
    "name": "nexus/timebank",
    "description": "Project NEXUS Timebanking Platform",
    "type": "project",
    "version": "1.5.0",
    "autoload": {
        "psr-4": {
            "Nexus\\": "src/",
            "App\\": "app/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\Tests\\": "tests/",
            "Tests\\": "tests/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "require": {
        "php": ">=8.2",
        "ext-bcmath": "*",
        "ext-curl": "*",
        "ext-dom": "*",
        "ext-fileinfo": "*",
        "ext-gd": "*",
        "ext-intl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-xml": "*",
        "ext-zip": "*",
        "chillerlan/php-qrcode": "^5.0",
        "dompdf/dompdf": "^3.1",
        "endroid/qr-code": "^6.0",
        "guzzlehttp/guzzle": "^7.10",
        "laravel/framework": "^12.54",
        "laravel/sanctum": "^4.3",
        "lbuchs/webauthn": "^2.2",
        "meilisearch/meilisearch-php": "^1.10",
        "minishlink/web-push": "^10.0",
        "pusher/pusher-php-server": "^7.2",
        "rubix/ml": "^2.0",
        "sendgrid/sendgrid": "^8.1",
        "sentry/sentry": "^4.0",
        "spomky-labs/otphp": "^11.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^10.5.62"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "suggest": {
        "ext-redis": "For Redis caching support",
        "ext-imagick": "For advanced image processing",
        "ext-memcached": "For Memcached caching support",
        "ext-sodium": "For modern cryptography support"
    }
}
