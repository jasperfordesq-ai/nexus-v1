      "js-yaml": "^3.15.0"
    },
    "form-data": "^4.0.6",
    "js-yaml": "^4.2.0",
    "postcss": "^8.5.10",
    "tar": "^7.5.16",
    "undici": "^6.27.0",
    "uuid": "^11.1.1",
    "ws@^6": "^6.2.4",
    "ws@^7": "^7.5.11"
  },
  "lint-staged": {
    "*.{ts,tsx}": "echo type-check deferred to CI"
  }
