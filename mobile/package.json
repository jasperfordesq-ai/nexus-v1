    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.9",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.18",
    "heroui-native": "^1.0.4",
    "i18next": "^25.8.17",
    "pusher-js": "^8.4.0",
