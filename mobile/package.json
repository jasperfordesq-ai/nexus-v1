{
  "name": "nexus-mobile",
  "version": "1.2.0",
  "license": "AGPL-3.0-or-later",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "type-check": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "prepackage": "npm run type-check && npm test -- --runInBand --silent && npx expo-doctor",
    "build:android:website": "node scripts/eas-build.js --platform android --profile website",
    "build:android:play": "node scripts/eas-build.js --platform android --profile production",
    "submit:android:internal": "npx eas-cli@latest submit -p android --profile production --latest",
    "verify:release": "node scripts/verify-release-config.mjs",
    "update:staging": "node scripts/publish-update.mjs staging",
    "update:production": "node scripts/publish-update.mjs production",
    "test": "jest",
    "test:ci": "jest --ci --bail --coverage",
    "test:watch": "jest --watch",
    "prepare": "cd .. && husky mobile/.husky || true"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@hookform/resolvers": "^5.4.0",
