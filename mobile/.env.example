# Project NEXUS Mobile — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is in .gitignore

# PHP API base URL (no trailing slash)
# Production:
EXPO_PUBLIC_API_URL=https://api.project-nexus.ie

# Android emulator → host machine localhost:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8090

# iOS simulator → host machine localhost:
# EXPO_PUBLIC_API_URL=http://localhost:8090

# Default tenant slug (used when no tenant is selected yet)
EXPO_PUBLIC_DEFAULT_TENANT=hour-timebank
