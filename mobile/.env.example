# Project NEXUS Mobile — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is in .gitignore

# PHP API base URL (no trailing slash)
# Production:
EXPO_PUBLIC_API_URL=https://api.project-nexus.ie

# Android emulator → host machine localhost:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8090

# iOS simulator → host machine localhost:
# EXPO_PUBLIC_API_URL=http://localhost:8090

# Default tenant slug (used when no tenant is selected yet)
EXPO_PUBLIC_DEFAULT_TENANT=hour-timebank

# Sentry error monitoring (optional but strongly recommended for production)
# Get DSN from: https://sentry.io → Your Project → Settings → Client Keys
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# EAS Project ID (from eas.json / Expo dashboard)
# EXPO_PUBLIC_EAS_PROJECT_ID=your-project-id

# Push notifications (optional - only needed for FCM setup)
# EXPO_PUBLIC_FCM_SENDER_ID=your-sender-id
