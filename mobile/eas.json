{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {
        "simulator": true
      },
      "cache": {
        "key": "nexus-dev-v1"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.project-nexus.ie",
        "EXPO_PUBLIC_DEFAULT_TENANT": "hour-timebank",
        "EXPO_PUBLIC_ALLOW_PRODUCTION_API_IN_DEV": "true",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "local-emulator": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {
        "simulator": true
      },
      "cache": {
        "key": "nexus-local-emulator-v1"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://10.0.2.2:8088",
        "EXPO_PUBLIC_DEFAULT_TENANT": "hour-timebank",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "cache": {
        "key": "nexus-preview-v1"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.project-nexus.ie",
        "EXPO_PUBLIC_DEFAULT_TENANT": "hour-timebank",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "website": {
      "distribution": "internal",
      "channel": "website",
      "android": {
        "buildType": "apk"
      },
      "cache": {
        "key": "nexus-website-apk-v1"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.project-nexus.ie",
        "EXPO_PUBLIC_DEFAULT_TENANT": "hour-timebank",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "cache": {
        "key": "nexus-prod-v1"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.project-nexus.ie",
        "EXPO_PUBLIC_DEFAULT_TENANT": "hour-timebank",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-key.json",
        "track": "internal"
      },
      "ios": {
        "ascAppId": "APPLE_APP_STORE_CONNECT_APP_ID"
      }
    }
  }
}
