{
  "expo": {
    "name": "Project NEXUS",
    "slug": "nexus-mobile",
    "scheme": "nexus",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#006FEE"
    },
    "ios": {
      "bundleIdentifier": "ie.hour.nexus",
      "buildNumber": "1",
      "supportsTablet": false,
      "associatedDomains": [
        "applinks:app.project-nexus.ie"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Take a photo for your profile picture or post.",
        "NSPhotoLibraryUsageDescription": "Choose a photo from your library for your profile or post.",
        "NSPhotoLibraryAddUsageDescription": "Save photos to your library."
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#006FEE"
      },
      "package": "ie.hour.nexus",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.project-nexus.ie"
            },
            {
              "scheme": "nexus"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#006FEE",
          "sounds": []
        }
      ],
      "expo-localization",
      "@sentry/react-native/expo",
      [
        "expo-build-properties",
        {
          "android": {
            "networkSecurityConfig": "./android-network-security-config.xml"
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
