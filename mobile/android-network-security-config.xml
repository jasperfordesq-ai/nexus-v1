<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Network Security Configuration for Project NEXUS

  Certificate pinning: pins the live leaf SPKI and the Google Trust Services
  WE1 intermediate SPKI as the rotation-safe backup.

  Pins last verified: 2026-07-14 — run scripts/get-cert-pins.sh to refresh after certificate rotation.
  Keep BACKUP pins from an intermediate CA so a certificate rotation doesn't lock users out.
-->
<network-security-config>
  <domain-config cleartextTrafficPermitted="false">
    <domain includeSubdomains="false">api.project-nexus.ie</domain>
    <pin-set expiration="2027-01-01">
      <!-- Leaf certificate pin — verified 2026-07-14 via scripts/get-cert-pins.sh -->
      <pin digest="SHA-256">Owkg3TiAdb9cU+XKSXkJfvD2tCx+supL5btxtXNJaJE=</pin>
      <!-- Intermediate CA backup pin — verified 2026-07-14 from the live chain -->
      <pin digest="SHA-256">kIdp6NNEd8wsugYyyIYFsi1ylMCED3hZbSR8ZFsa/A4=</pin>
    </pin-set>
  </domain-config>

  <!-- Default: use system trust store, no cleartext traffic permitted -->
  <base-config cleartextTrafficPermitted="false">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>
</network-security-config>
