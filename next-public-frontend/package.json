  "type": "module",
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 5175",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "next typegen && tsc --noEmit",
    "check:manifests": "vitest run src/lib/__tests__/shadow-manifest-validation.test.ts",
    "check:messages": "vitest run src/lib/__tests__/public-messages-validation.test.ts",
    "check:no-js-html": "vitest run src/ui/__tests__/PublicRouteNoJsHtml.test.tsx",
    "check": "npm run check:manifests && npm run check:messages && npm run check:no-js-html && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@heroui/react": "3.1.0",
    "@heroui/styles": "3.1.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "24.10.2",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.16",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
