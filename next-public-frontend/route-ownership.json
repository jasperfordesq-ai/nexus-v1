{
  "mode": "shadow",
  "description": "Shadow-mode route ownership for the Next.js public frontend. This manifest documents intended ownership only; it does not activate production routing.",
  "nextPublicRoutes": [
    { "pattern": "/", "routeKey": "home", "labelKey": "pages.home.title" },
    { "pattern": "/about", "routeKey": "about", "labelKey": "pages.about.title" },
    { "pattern": "/help", "routeKey": "help", "labelKey": "pages.help.title" },
    { "pattern": "/contact", "routeKey": "contact", "labelKey": "pages.contact.title" },
    { "pattern": "/faq", "routeKey": "faq", "labelKey": "pages.faq.title" },
    { "pattern": "/privacy", "routeKey": "privacy", "labelKey": "pages.privacy.title" },
    { "pattern": "/terms", "routeKey": "terms", "labelKey": "pages.terms.title" },
    { "pattern": "/accessibility", "routeKey": "accessibility", "labelKey": "pages.accessibility.title" },
    { "pattern": "/blog", "routeKey": "blog-index", "labelKey": "pages.blog.title" },
    { "pattern": "/blog/:slug", "routeKey": "blog-detail", "labelKey": "pages.blogDetail.title" },
    { "pattern": "/page/:slug", "routeKey": "cms-page", "labelKey": "pages.cmsPage.title" },
    { "pattern": "/listings", "routeKey": "listings", "labelKey": "pages.listings.title" },
    { "pattern": "/listings/:id", "routeKey": "listingDetail", "labelKey": "pages.listingDetail.title" },
    { "pattern": "/events", "routeKey": "events", "labelKey": "pages.events.title" },
    { "pattern": "/events/:id", "routeKey": "eventDetail", "labelKey": "pages.eventDetail.title" },
    { "pattern": "/jobs", "routeKey": "jobs", "labelKey": "pages.jobs.title" },
    { "pattern": "/jobs/:id", "routeKey": "jobDetail", "labelKey": "pages.jobDetail.title" },
    { "pattern": "/organisations", "routeKey": "organisations", "labelKey": "pages.organisations.title" },
    { "pattern": "/organisations/:id", "routeKey": "organisationDetail", "labelKey": "pages.organisationDetail.title" },
    { "pattern": "/resources", "routeKey": "resources", "labelKey": "pages.resources.title" },
    { "pattern": "/kb", "routeKey": "kb", "labelKey": "pages.kb.title" },
    { "pattern": "/kb/:id", "routeKey": "kbDetail", "labelKey": "pages.kbDetail.title" },
    { "pattern": "/marketplace", "routeKey": "marketplace", "labelKey": "pages.marketplace.title" },
    { "pattern": "/marketplace/:id", "routeKey": "marketplaceDetail", "labelKey": "pages.marketplaceDetail.title" }
  ],
  "vitePrivatePrefixes": [
    "achievements",
    "admin",
    "broker",
    "connections",
    "dashboard",
    "feed",
    "goals",
    "groups",
    "leaderboard",
    "login",
    "matches",
    "members",
    "messages",
    "notifications",
    "onboarding",
    "profile",
    "register",
    "settings",
    "super-admin",
    "wallet"
  ],
  "vitePrivatePatterns": [
    "/events/new",
    "/events/:id/edit",
    "/jobs/new",
    "/jobs/:id/edit",
    "/listings/new",
    "/listings/:id/edit",
    "/marketplace/new",
    "/marketplace/:id/edit",
    "/organisations/new",
    "/organisations/:id/edit",
    "/resources/new",
    "/resources/:id/edit"
  ]
}
