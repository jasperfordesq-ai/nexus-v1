# NEXUS React Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# API Configuration
VITE_API_BASE=/api
VITE_API_URL=http://localhost:8090

# Default Tenant (for development)
VITE_DEFAULT_TENANT_ID=1
VITE_DEFAULT_TENANT_SLUG=hour-timebank

# Google Maps (Places Autocomplete + Advanced Markers)
VITE_GOOGLE_MAPS_API_KEY=
# Map ID required for AdvancedMarker — create at Google Cloud Console > Maps > Map Management
VITE_GOOGLE_MAPS_MAP_ID=
