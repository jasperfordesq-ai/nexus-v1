{
  "name": "nexus-react-frontend",
  "private": true,
  "version": "1.5.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "copy-locales": "node -e \"const fs=require('fs');if(fs.existsSync('../lang')){fs.cpSync('../lang','public/locales',{recursive:true,force:true});console.log('[i18n] lang/ copied to public/locales/')}else{console.log('[i18n] ../lang not found, using committed locales')}\"",
    "i18n:status": "i18next-cli status",
    "i18n:sync": "i18next-cli sync",
    "i18n:lint": "i18next-cli lint",
    "i18n:types": "i18next-cli types",
    "prebuild": "npm run copy-locales",
    "build": "vite build",
    "build:check": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings 1000 && tsc --noEmit",
    "test": "cross-env NODE_OPTIONS=\"--max-old-space-size=20480\" vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "cross-env NODE_OPTIONS=\"--max-old-space-size=20480\" vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint:fix": "eslint src --fix",
    "lhci": "lhci autorun"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@googlemaps/markerclusterer": "^2.6.2",
    "@heroui/react": "^2.6.0",
    "@heroui/theme": "^2.4.0",
    "@lexical/html": "^0.40.0",
    "@lexical/link": "^0.40.0",
    "@lexical/list": "^0.40.0",
    "@lexical/react": "^0.40.0",
    "@lexical/rich-text": "^0.40.0",
    "@lexical/selection": "^0.40.0",
    "@lexical/utils": "^0.40.0",
    "@sentry/react": "^10.39.0",
    "@simplewebauthn/browser": "^13.2.2",
    "@stripe/react-stripe-js": "^6.0.0",
    "@stripe/stripe-js": "^9.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/papaparse": "^5.5.2",
    "@vis.gl/react-google-maps": "^1.7.1",
    "dompurify": "^3.4.0",
    "framer-motion": "^11.0.0",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-chained-backend": "^5.0.3",
    "i18next-http-backend": "^3.0.2",
    "i18next-localstorage-backend": "^4.3.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lexical": "^0.40.0",
    "lucide-react": "^0.453.0",
    "marked": "^17.0.5",
    "papaparse": "^5.5.3",
    "pusher-js": "^8.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "serialize-javascript": "^7.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/fs-extra": "^11.0.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/slice-ansi": "^5.0.2",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "i18next-cli": "^1.54.2",
    "jsdom": "^25.0.0",
    "sharp": "^0.33.0",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "5.7.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-image-optimizer": "^1.1.8",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.4",
    "vitest-axe": "^0.1.0"
  }
}
