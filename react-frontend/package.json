{
  "name": "nexus-react-frontend",
  "private": true,
  "version": "1.5.5",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "packageManager": "npm@10.9.8",
  "scripts": {
    "predev": "npm run copy-changelog",
    "dev": "vite",
    "dev:laravel": "cross-env VITE_BACKEND_TARGET=laravel VITE_API_URL=http://localhost:8090 npm run dev -- --mode laravel",
    "dev:dotnet": "cross-env VITE_BACKEND_TARGET=dotnet VITE_API_URL=http://localhost:5080 npm run dev -- --mode dotnet",
    "copy-locales": "node scripts/copy-locales.mjs",
    "copy-changelog": "node scripts/copy-changelog.mjs",
    "inventory:api-calls": "node scripts/inventory-api-calls.mjs",
    "certification:worksheets": "node scripts/generate-certification-worksheets.mjs",
    "smoke:laravel-manifest": "node scripts/generate-laravel-smoke-manifest.mjs",
    "check:backend-guardrails": "node scripts/check-backend-guardrails.mjs",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "check:nested-interactive": "node scripts/check-nested-interactive.mjs",
    "check:locale-formatting": "node scripts/check-locale-formatting.mjs",
    "check:design-tokens": "node scripts/check-design-tokens.mjs",
    "check:admin-i18n": "eslint src/admin --quiet",
    "check:dual-backend-prep": "npm run check:backend-guardrails && npm run test:api-inventory && npm run test:certification-worksheets && npm run test:laravel-smoke-manifest && npm run inventory:api-calls && npm run certification:worksheets && npm run smoke:laravel-manifest",
    "test:api-inventory": "node --test scripts/inventory-api-calls.test.mjs",
    "test:backend-guardrails": "node --test scripts/check-backend-guardrails.test.mjs",
    "test:certification-worksheets": "node --test scripts/generate-certification-worksheets.test.mjs",
    "test:laravel-smoke-manifest": "node --test scripts/generate-laravel-smoke-manifest.test.mjs",
    "i18n:status": "i18next-cli status",
    "i18n:sync": "i18next-cli sync",
    "i18n:lint": "i18next-cli lint",
    "i18n:types": "i18next-cli types",
    "i18n:interpolation-parity": "node scripts/check-i18n-interpolation-parity.mjs",
    "prebuild": "node --test scripts/prerender-privacy-policy.test.mjs && npm run check:nested-interactive && npm run check:locale-formatting && npm run check:design-tokens && npm run check:admin-i18n && npm run copy-locales && npm run copy-changelog",
    "build": "vite build",
    "build:laravel": "cross-env VITE_BACKEND_TARGET=laravel npm run build -- --mode laravel",
    "build:dotnet": "cross-env VITE_BACKEND_TARGET=dotnet VITE_API_URL=http://localhost:5080 npm run build -- --mode dotnet",
    "analyze:bundle": "cross-env VITE_BUNDLE_ANALYZE=1 VITE_BACKEND_TARGET=laravel vite build --mode laravel",
    "postbuild": "node scripts/prerender.mjs",
    "prerender": "node scripts/prerender.mjs",
    "build:check": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings 10 && cross-env NODE_OPTIONS=\"--max-old-space-size=20480\" tsc --noEmit",
    "test": "cross-env NODE_OPTIONS=\"--max-old-space-size=20480\" vitest",
    "test:groups": "cross-env NODE_OPTIONS=\"--max-old-space-size=20480\" NEXUS_FAIL_ON_UNEXPECTED_CONSOLE=1 vitest run --pool=forks --poolOptions.forks.singleFork=true src/pages/groups src/components/ideation src/admin/modules/groups",
    "test:a11y": "cross-env NODE_OPTIONS=\"--max-old-space-size=20480\" NEXUS_FAIL_ON_UNEXPECTED_CONSOLE=1 vitest run src/pages/caring-community/__tests__/caring-community.a11y.test.tsx src/test/accessibility.test.tsx",
    "test:ui-contracts": "cross-env NODE_OPTIONS=\"--max-old-space-size=20480\" NEXUS_FAIL_ON_UNEXPECTED_CONSOLE=1 vitest run --pool=forks --poolOptions.forks.singleFork=true src/components/ui src/components/layout/SearchOverlay.test.tsx src/components/layout/__tests__/SearchOverlay.test.tsx src/components/layout/__tests__/SearchOverlay.a11y.test.tsx",
    "test:ui": "vitest --ui",
    "test:coverage": "cross-env NODE_OPTIONS=\"--max-old-space-size=20480\" vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint:fix": "eslint src --fix",
    "lhci": "lhci autorun"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@googlemaps/markerclusterer": "^2.6.2",
    "@heroui/react": "^3.1.0",
