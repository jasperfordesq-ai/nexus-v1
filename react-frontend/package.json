{
  "name": "nexus-react-frontend",
  "private": true,
  "version": "1.5.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "copy-locales": "node scripts/copy-locales.mjs",
    "i18n:status": "i18next-cli status",
    "i18n:sync": "i18next-cli sync",
    "i18n:lint": "i18next-cli lint",
    "i18n:types": "i18next-cli types",
    "prebuild": "npm run copy-locales",
    "build": "vite build",
    "postbuild": "node scripts/prerender.mjs",
    "prerender": "node scripts/prerender.mjs",
    "build:check": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings 1000 && cross-env NODE_OPTIONS=\"--max-old-space-size=20480\" tsc --noEmit",
    "test": "cross-env NODE_OPTIONS=\"--max-old-space-size=20480\" vitest",
    "test:a11y": "cross-env NODE_OPTIONS=\"--max-old-space-size=20480\" vitest run src/pages/caring-community/__tests__/caring-community.a11y.test.tsx src/test/accessibility.test.tsx",
    "test:ui": "vitest --ui",
    "test:coverage": "cross-env NODE_OPTIONS=\"--max-old-space-size=20480\" vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint:fix": "eslint src --fix",
    "lhci": "lhci autorun"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@googlemaps/markerclusterer": "^2.6.2",
    "@heroui/react": "^3.0.3",
    "@heroui/theme": "^2.4.0",
    "@lexical/html": "^0.44.0",
    "@lexical/link": "^0.44.0",
    "@lexical/list": "^0.44.0",
    "@lexical/react": "^0.44.0",
    "@lexical/rich-text": "^0.44.0",
    "@lexical/selection": "^0.44.0",
    "@lexical/utils": "^0.44.0",
    "@sentry/react": "^10.51.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/papaparse": "^5.5.2",
    "@vis.gl/react-google-maps": "^1.8.3",
    "dompurify": "^3.4.2",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-chained-backend": "^5.0.3",
    "i18next-http-backend": "^4.0.0",
    "i18next-localstorage-backend": "^4.3.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lexical": "^0.44.0",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.3",
    "papaparse": "^5.5.3",
    "pusher-js": "^8.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "basic-ftp": ">=5.2.3",
    "postcss": ">=8.5.10",
    "serialize-javascript": "^7.0.4",
    "tmp": ">=0.2.4",
    "uuid": ">=14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/fs-extra": "^11.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/slice-ansi": "^7.1.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "i18next-cli": "^1.56.9",
    "jsdom": "^29.1.1",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0"
  }
}
