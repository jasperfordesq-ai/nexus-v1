    "@lexical/html": "^0.44.0",
    "@lexical/link": "^0.44.0",
    "@lexical/list": "^0.44.0",
    "@lexical/react": "^0.44.0",
    "@lexical/rich-text": "^0.44.0",
    "@lexical/selection": "^0.44.0",
    "@lexical/utils": "^0.44.0",
    "@react-aria/focus": "^3.22.0",
    "@react-aria/interactions": "^3.28.0",
    "@sentry/react": "^10.52.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/papaparse": "^5.5.2",
    "@uiw/react-codemirror": "^4.25.10",
    "@vis.gl/react-google-maps": "^1.8.3",
    "dompurify": "^3.4.2",
    "grapesjs": "^0.21.2",
    "grapesjs-blocks-basic": "^1.0.2",
    "grapesjs-custom-code": "^1.0.2",
    "grapesjs-mjml": "1.0.8",
    "grapesjs-plugin-forms": "^2.0.6",
    "grapesjs-preset-webpage": "^1.0.3",
    "grapesjs-tabs": "^1.0.6",
    "grapesjs-tooltip": "^0.1.8",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-chained-backend": "^5.0.4",
    "i18next-http-backend": "^3.0.6",
    "i18next-localstorage-backend": "^4.3.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lexical": "^0.44.0",
    "lucide-react": "^0.453.0",
    "marked": "^17.0.5",
    "papaparse": "^5.5.3",
    "postcss": ">=8.5.10",
    "pusher-js": "^8.5.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@babel/core": "^7.29.6",
    "@lhci/utils": {
      "js-yaml": "^3.15.0"
    },
    "basic-ftp": ">=5.2.3",
    "esbuild": ">=0.28.1",
    "form-data": "^4.0.6",
    "js-yaml": "^4.2.0",
    "postcss": ">=8.5.10",
    "serialize-javascript": "^7.0.4",
    "tar": "^7.5.16",
    "tmp": ">=0.2.6",
    "underscore": ">=1.13.8",
    "uuid": ">=14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/fs-extra": "^11.0.4",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/slice-ansi": "^5.0.2",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "heroui-cli": "^3.0.2",
    "i18next-cli": "^1.56.11",
    "jsdom": "^25.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.6",
    "vite-plugin-image-optimizer": "^1.1.8",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.6",
    "vitest-axe": "^0.1.0"
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "^0.27.7"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10"
  }
}
