<?xml version="1.0" encoding="UTF-8"?>
<!--
  OWASP Dependency-Check Suppression File
  ========================================
  Suppresses known false positives and accepted-risk CVEs.
  Each entry documents WHY the suppression is safe.

  Reviewed: 2026-02-28
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

  <!--
    FALSE POSITIVE: phpunit/php-file-iterator → matched to generic "file" CPE
    CVE-2019-18218 and CVE-2014-9653 are vulnerabilities in the Unix "file"
    command (libmagic), NOT the PHPUnit file iterator. The CPE
    cpe:2.3:a:file_project:file:* is a wrong match.
    PHPUnit is a dev-only dependency and never runs in production.
  -->
  <suppress>
    <notes><![CDATA[
      FP: phpunit/php-file-iterator is not the Unix "file" command.
      CVE-2019-18218 affects libmagic (file command), not PHPUnit.
    ]]></notes>
    <packageUrl regex="true">^pkg:composer/phpunit/php-file-iterator@.*$</packageUrl>
    <vulnerabilityName>CVE-2019-18218</vulnerabilityName>
  </suppress>
  <suppress>
    <notes><![CDATA[
      FP: phpunit/php-file-iterator is not the Unix "file" command.
      CVE-2014-9653 affects libmagic (file command), not PHPUnit.
    ]]></notes>
    <packageUrl regex="true">^pkg:composer/phpunit/php-file-iterator@.*$</packageUrl>
    <vulnerabilityName>CVE-2014-9653</vulnerabilityName>
  </suppress>

  <!--
    FALSE POSITIVE: pusher/pusher-php-server → matched to generic "server-php" CPE
    CVE-2015-10086 is a vulnerability in a WordPress plugin called "server-php",
    NOT the Pusher PHP SDK. The CPE cpe:2.3:a:server-php_project:server-php:*
    is a wrong match.
  -->
  <suppress>
    <notes><![CDATA[
      FP: pusher/pusher-php-server is not the "server-php" WordPress plugin.
      CVE-2015-10086 affects flavors-flavor/server-php WordPress plugin.
    ]]></notes>
    <packageUrl regex="true">^pkg:composer/pusher/pusher-php-server@.*$</packageUrl>
    <vulnerabilityName>CVE-2015-10086</vulnerabilityName>
  </suppress>

  <!--
    ACCEPTED RISK: web-token/jwt-library@4.1.3 — CVE-2025-45770 (CVSS 7.0)
    No patched version available yet (4.1.3 is the latest stable).
    The vulnerability relates to JWT signature validation edge cases.
    Our usage is limited to internal API token handling with controlled inputs.
    Will update when a fix is released. Tracked for next review.
  -->
  <suppress until="2026-06-01Z">
    <notes><![CDATA[
      ACCEPTED RISK: CVE-2025-45770 in jwt-library 4.1.3.
      No fix available — 4.1.3 is latest. Suppress until 2026-06-01 and re-evaluate.
    ]]></notes>
    <packageUrl regex="true">^pkg:composer/web-token/jwt-library@4\.1\.3$</packageUrl>
    <vulnerabilityName>CVE-2025-45770</vulnerabilityName>
  </suppress>

  <!--
    FALSE POSITIVE: minimatch@9.0.6 in root package-lock.json
    GHSA-3ppc-4f35-3m26 was fixed in 9.0.6, but OWASP may still flag
    the root package-lock.json if it contains stale entries. The actual
    dependency in react-frontend/node_modules is 9.0.6 (patched).
  -->
  <suppress>
    <notes><![CDATA[
      minimatch has been updated to 9.0.6 in react-frontend.
      Root package-lock.json may contain a stale reference.
    ]]></notes>
    <packageUrl regex="true">^pkg:npm/minimatch@9\.0\.[56]$</packageUrl>
    <vulnerabilityName>GHSA-3ppc-4f35-3m26</vulnerabilityName>
  </suppress>

  <!--
    DEV-ONLY: PHPUnit CVE-2026-24765 — phpunit and sub-packages
    PHPUnit, php-code-coverage, and php-timer are TEST-ONLY dependencies.
    They are never installed on the production server (require-dev in
    composer.json). This CVE cannot be exploited in our environment.
    CVE-2017-9841 is an old remote code execution in PHPUnit's test
    result handler — again, never exposed on production.
  -->
  <suppress>
    <notes><![CDATA[
      DEV-ONLY: All phpunit/* packages are in require-dev and never deployed.
      CVE-2026-24765 and CVE-2017-9841 cannot be exploited in production.
    ]]></notes>
    <packageUrl regex="true">^pkg:composer/phpunit/.*$</packageUrl>
    <vulnerabilityName>CVE-2026-24765</vulnerabilityName>
  </suppress>
  <suppress>
    <notes><![CDATA[
      DEV-ONLY: phpunit/php-timer matched to generic phpunit CPE.
      CVE-2017-9841 (PHPUnit remote code via HTTP) — dev-only, never deployed.
    ]]></notes>
    <packageUrl regex="true">^pkg:composer/phpunit/.*$</packageUrl>
    <vulnerabilityName>CVE-2017-9841</vulnerabilityName>
  </suppress>

  <!--
    FALSE POSITIVE: joomla/string matched to Joomla CMS CPE
    joomla/string is a standalone PHP string utility library.
    OWASP incorrectly matches it to the full Joomla CMS CPE, triggering
    dozens of ancient Joomla CMS CVEs (2007-2008). The CVE element does not
    support regex — suppress by packageUrl + each vulnerabilityName pattern.
  -->
  <suppress>
    <notes><![CDATA[
      FP: joomla/string is a PHP string utility, not the Joomla CMS.
      All old CVE matches are against the Joomla CMS CPE — wrong package.
    ]]></notes>
    <packageUrl regex="true">^pkg:composer/joomla/string@.*$</packageUrl>
    <vulnerabilityName regex="true">CVE-200[678]-.*</vulnerabilityName>
  </suppress>

  <!--
    MOBILE-ONLY: undici WebSocket DoS CVEs in mobile/package-lock.json
    undici is used by the Capacitor mobile app (mobile/ directory).
    The mobile app compiles to APK/IPA — it is NOT deployed to the web server.
    Fixed in undici 6.24.0 / 7.24.0. Mobile deps tracked for update separately.
    These GHSAs correspond to CVE-2026-1526, CVE-2026-1528, CVE-2026-2229.
  -->
  <suppress>
    <notes><![CDATA[
      MOBILE-ONLY: undici in mobile/package-lock.json (Capacitor APK).
      Not deployed to the web server. Will update mobile deps separately.
    ]]></notes>
    <packageUrl regex="true">^pkg:npm/undici@6\.2[0-3]\..*$</packageUrl>
    <vulnerabilityName>GHSA-vrm6-8vpv-qv8q</vulnerabilityName>
  </suppress>
  <suppress>
    <notes><![CDATA[
      MOBILE-ONLY: undici WebSocket DoS — mobile APK only, not web server.
    ]]></notes>
    <packageUrl regex="true">^pkg:npm/undici@6\.2[0-3]\..*$</packageUrl>
    <vulnerabilityName>GHSA-f269-vfmq-vjvj</vulnerabilityName>
  </suppress>
  <suppress>
    <notes><![CDATA[
      MOBILE-ONLY: undici WebSocket DoS — mobile APK only, not web server.
    ]]></notes>
    <packageUrl regex="true">^pkg:npm/undici@6\.2[0-3]\..*$</packageUrl>
    <vulnerabilityName>GHSA-v9p9-hfj2-hcw8</vulnerabilityName>
  </suppress>

  <!--
    FALSE POSITIVE: certifi in vendor/mockery/mockery/docs/requirements.txt
    This is a Python requirements.txt inside the DOCUMENTATION folder of the
    Mockery PHP testing library (require-dev). We never install Python in this
    project and this file is never executed. certifi CVE-2024-39689 relates to
    a compromised root CA — entirely irrelevant to a PHP/Node project.
  -->
  <suppress>
    <notes><![CDATA[
      FP: certifi is in mockery docs/requirements.txt — a Python file inside
      a PHP dev-only test library. Never installed or run. Not a web risk.
    ]]></notes>
    <packageUrl regex="true">^pkg:pypi/certifi@.*$</packageUrl>
    <vulnerabilityName>CVE-2024-39689</vulnerabilityName>
  </suppress>

</suppressions>
