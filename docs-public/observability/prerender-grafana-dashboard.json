{
  "title": "NEXUS Prerender Engine",
  "uid": "nexus-prerender",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["nexus", "prerender", "seo"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(nexus_prerender_tenant_rendered, slug)",
        "refresh": 1,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Health",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "GREEN", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "YELLOW", "color": "yellow" } } },
            { "type": "value", "options": { "2": { "text": "RED", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 2 }
          ] }
        }
      },
      "targets": [{ "expr": "nexus_prerender_health_status" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Circuit breaker",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "TRIPPED", "color": "red" } } }
          ]
        }
      },
      "targets": [{ "expr": "nexus_prerender_breaker_tripped" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Coverage",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "green", "value": 0.95 }
          ] }
        }
      },
      "targets": [{ "expr": "nexus_prerender_coverage_ratio" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Oldest queued age (s)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 120 }, { "color": "red", "value": 600 }
          ] }
        }
      },
      "targets": [{ "expr": "nexus_prerender_queue_oldest_age_seconds" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active jobs",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "nexus_prerender_jobs_active" }]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Queued",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "nexus_prerender_jobs_queued" }]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Snapshots — missing / stale / content-stale",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "nexus_prerender_snapshots_missing", "legendFormat": "missing" },
        { "expr": "nexus_prerender_snapshots_stale",   "legendFormat": "age stale" },
        { "expr": "nexus_prerender_content_stale_total", "legendFormat": "content stale" },
        { "expr": "nexus_prerender_asset_invalid_total", "legendFormat": "asset invalid" }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Queue depth + oldest age",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "nexus_prerender_jobs_queued", "legendFormat": "queued" },
        { "expr": "nexus_prerender_jobs_active", "legendFormat": "active" },
        { "expr": "nexus_prerender_queue_oldest_age_seconds", "legendFormat": "oldest age (s)" }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Job outcomes (lifetime cumulative)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "nexus_prerender_jobs_total{status=\"succeeded\"}", "legendFormat": "succeeded" },
        { "expr": "nexus_prerender_jobs_total{status=\"partial\"}",   "legendFormat": "partial" },
        { "expr": "nexus_prerender_jobs_total{status=\"failed\"}",    "legendFormat": "failed" },
        { "expr": "nexus_prerender_jobs_total{status=\"cancelled\"}", "legendFormat": "cancelled" }
      ]
    },
    {
      "id": 21,
      "type": "bargauge",
      "title": "Missing routes per tenant",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{ "expr": "topk(20, nexus_prerender_tenant_missing{slug=~\"$tenant\"})", "legendFormat": "{{slug}}" }]
    },
    {
      "id": 30,
      "type": "stat",
      "title": "Cache size",
      "gridPos": { "x": 0, "y": 20, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [{ "expr": "nexus_prerender_cache_bytes" }]
    },
    {
      "id": 31,
      "type": "stat",
      "title": "Last run duration",
      "gridPos": { "x": 6, "y": 20, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{ "expr": "nexus_prerender_last_run_duration_seconds" }]
    },
    {
      "id": 32,
      "type": "stat",
      "title": "Recent failures (backoff)",
      "gridPos": { "x": 12, "y": 20, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }
          ] }
        }
      },
      "targets": [{ "expr": "nexus_prerender_failures_recent" }]
    },
    {
      "id": 33,
      "type": "stat",
      "title": "Breaker auto-resume",
      "gridPos": { "x": 18, "y": 20, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "dateTimeFromNow" } },
      "targets": [{ "expr": "nexus_prerender_breaker_until_seconds * 1000" }]
    }
  ]
}
