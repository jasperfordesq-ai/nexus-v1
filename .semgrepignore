# =============================================================================
# Semgrep Ignore File
# =============================================================================
# Controls which files/directories Semgrep skips during SAST scanning.
# Uses .gitignore syntax.
#
# Last reviewed: 2026-02-28
# =============================================================================

# ── Dependencies & build artifacts ──────────────────────────────────────────
vendor/
node_modules/
react-frontend/dist/
react-frontend/.vite/
sales-site/dist/
sales-site/.next/
sales-site/node_modules/

# ── Legacy PHP frontend views (DEAD CODE) ──────────────────────────────────
# The React frontend is the primary UI. These PHP themes are dead legacy code
# and are never served to users. See CLAUDE.md "LEGACY PHP THEMES ARE DEAD".
views/civicone/
views/starter/

# Legacy modern theme views (non-admin only — admin views are still active)
views/modern/layouts/
views/modern/pages/
views/modern/partials/
views/modern/components/
views/modern/auth/
views/modern/errors/

# ── Deprecated controllers (moved to _deprecated/) ────────────────────────
# These are fully deprecated and no longer routed. Code is kept for reference
# only. All alerts in these files are known and accepted.
_deprecated/

# ── Test files ──────────────────────────────────────────────────────────────
tests/
e2e/

# ── Database migrations (SQL only, no PHP logic) ───────────────────────────
migrations/

# ── Scripts & tooling ──────────────────────────────────────────────────────
scripts/

# ── Config / non-executable ────────────────────────────────────────────────
docs/
*.md
*.json
*.lock
*.xml
*.yml
*.yaml
*.css
*.svg
*.sql
